#!/usr/bin/env bash

# Defaults
URGENCY="normal"
TIMEOUT="5000"
PRINT_ONLY=false
TITLE=""

usage() {
    echo "Usage: remind-me [OPTIONS] CONTENT..."
    echo "Options:"
    echo "  -i, --important  Sticky (Critical urgency)"
    echo "  -p, --print      Print command string (for 'at')"
    echo "  -t, --title      Set a custom title"
    exit 1
}

# Handle long-form flags
for arg in "$@"; do
    case "$arg" in
        --important) set -- "$@" "-i" ;;
        --print)     set -- "$@" "-p" ;;
        --title)     set -- "$@" "-t" ;;
    esac
done

# Parse options
while getopts "ipt:" opt; do
    case $opt in
        i) URGENCY="critical"; TIMEOUT="0" ;;
        p) PRINT_ONLY=true ;;
        t) TITLE="$OPTARG" ;;
        *) usage ;;
    esac
done
shift $((OPTIND-1))

# Check if there is any content left
if [ "$#" -lt 1 ]; then
    usage
fi

# SQUASH: Take all remaining arguments and join them with spaces
CONTENT="$*"

# Environment context
ENV_VARS=$(printf "DISPLAY=%q DBUS_SESSION_BUS_ADDRESS=%q" \
    "${DISPLAY:-:0}" \
    "${DBUS_SESSION_BUS_ADDRESS:-unix:path=/run/user/$(id -u)/bus}")

# Construct the command
CMD=$(printf "notify-send -u %s -t %s %q %q" \
    "$URGENCY" \
    "$TIMEOUT" \
    "$TITLE" \
    "$CONTENT")

if [ "$PRINT_ONLY" = true ]; then
    echo "$ENV_VARS $CMD"
else
    eval "$ENV_VARS $CMD"
fi

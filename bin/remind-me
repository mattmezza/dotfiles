#!/usr/bin/env bash

# Defaults
URGENCY="normal"
TIMEOUT="5000"
PRINT_ONLY=false
TITLE=""

usage() {
    echo "Usage: remind-me [OPTIONS] 'CONTENT'"
    echo "Options:"
    echo "  -i, --important  Sticky (Critical urgency)"
    echo "  -p, --print      Print command string (for 'at')"
    echo "  -t, --title      Set a custom title"
    exit 1
}

# Handle long-form flags
for arg in "$@"; do
    case "$arg" in
        --important) set -- "$@" "-i" ;;
        --print)     set -- "$@" "-p" ;;
        --title)     set -- "$@" "-t" ;;
    esac
done

# Parse options
while getopts "ipt:" opt; do
    case $opt in
        i) URGENCY="critical"; TIMEOUT="0" ;;
        p) PRINT_ONLY=true ;;
        t) TITLE="$OPTARG" ;;
        *) usage ;;
    esac
done
shift $((OPTIND-1))

# The only remaining positional argument is the content
if [ "$#" -lt 1 ]; then
    usage
fi

CONTENT="$1"

# Environment context for X11/Wayland/DBus
ENV_VARS=$(printf "DISPLAY=%q DBUS_SESSION_BUS_ADDRESS=%q" \
    "${DISPLAY:-:0}" \
    "${DBUS_SESSION_BUS_ADDRESS:-unix:path=/run/user/$(id -u)/bus}")

# Construct the command
# If TITLE is empty, it passes an empty string which notify-send handles gracefully
CMD=$(printf "notify-send -u %s -t %s %q %q" \
    "$URGENCY" \
    "$TIMEOUT" \
    "$TITLE" \
    "$CONTENT")

if [ "$PRINT_ONLY" = true ]; then
    echo "$ENV_VARS $CMD"
else
    eval "$ENV_VARS $CMD"
fi
